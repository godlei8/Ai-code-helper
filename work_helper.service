[Unit]
Description=Work Helper AI Application
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/work_helper
ExecStart=/usr/lib/jvm/java-21-alibaba-dragonwell-21.0.5.0.5-1.1.al8.x86_64/bin/java -jar work_helper-0.0.1-SNAPSHOT.jar --spring.profiles.active=prod
