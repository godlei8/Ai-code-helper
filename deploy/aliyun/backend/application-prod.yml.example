server:
  port: 8081
  servlet:
    context-path: /api

spring:
  application:
    name: work_helper

langchain4j:
  community:
    dashscope:
      chat-model:
        api-key: ${DASHSCOPE_API_KEY}
        model-name: qwen-plus
      embedding-model:
        api-key: ${DASHSCOPE_API_KEY}
        model-name: text-embedding-v4
      streaming-chat-model:
        api-key: ${DASHSCOPE_API_KEY}
        model-name: qwen-plus

bigmodel:
  api-key: ${BIGMODEL_API_KEY}
